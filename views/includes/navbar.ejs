<!DOCTYPE html>
<header>
    <div class="logo">🌾 Farmer's Marketplace</div>
    <nav>
        <ul class="nav-links">
            <li><a href="/">Home</a></li>
            <li><a href="/buy">Buy Crops</a></li>
            <li><a href="/sell">Sell Crops</a></li>
            <li><a href="/prices">Market Prices</a></li>

            <% if (currentUser && currentUser.username) { %>
                <li class="account-dropdown">
                    <span class="account-toggle">
                        <% if (currentUser.profileImage) { %>
                            <img src="<%= currentUser.profileImage %>" alt="Profile" class="profile-img">
                        <% } else { %>
                            <i class="fa fa-user-circle profile-placeholder"></i>
                        <% } %>
                        <%= currentUser.username %> <i class="fa fa-caret-down"></i>
                    </span>
                    <ul class="dropdown-content">
                        <li><a href="/dashboard"><i class="fa fa-chart-line"></i> My Dashboard</a></li>
                        <li><a href="/profile"><i class="fa fa-user-edit"></i> Profile</a></li>
                        <li><a href="/orders"><i class="fa fa-shopping-basket"></i> My Orders</a></li>
                        <li class="logout"><a href="/logout"><i class="fa fa-sign-out-alt"></i> Logout</a></li>
                    </ul>
                </li>
            <% } else { %>
                <li class="account-dropdown">
                    <span class="account-toggle">
                        <i class="fa fa-user"></i> Account <i class="fa fa-caret-down"></i>
                    </span>
                    <ul class="dropdown-content">
                        <li><a href="/signup"><i class="fa fa-user-plus"></i> Sign Up</a></li>
                        <li><a href="/login"><i class="fa fa-lock"></i> Login</a></li>
                    </ul>
                </li>
            <% } %>
        </ul>

        <div class="hamburger">
            <span></span>
            <span></span>
            <span></span>
        </div>
    </nav>

    <style>
        :root {
            /* Vibrant Green Gradient Palette */
            --gradient-start: #2ecc71;     /* Bright green */
            --gradient-middle: #27ae60;    /* Deep green */
            --gradient-end: #2c3e50;       /* Dark blue-green */
            --text-primary: #ffffff;       /* White text */
            --text-secondary: #f1f2f6;     /* Soft off-white */
            --accent-color: #2ed573;       /* Bright highlight green */
            --hover-color: #healthy-green;
            --background-color: #f4f6f7;   /* Light gray background */
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', 'Segoe UI', Roboto, sans-serif;
        }

        body {
            background-color: var(--background-color);
            color: #2c3e50;
            line-height: 1.6;
            padding-top: 80px;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: linear-gradient(135deg, var(--gradient-start), var(--gradient-middle), var(--gradient-end));
            background-size: 200% 200%;
            color: var(--text-primary);
            padding: 15px 5%;
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            animation: GradientBackground 10s ease infinite;
            transition: all 0.3s ease;
        }

        @keyframes GradientBackground {
            0% {background-position: 0% 50%;}
            50% {background-position: 100% 50%;}
            100% {background-position: 0% 50%;}
        }

        .logo {
            font-size: 1.75rem;
            font-weight: 800;
            letter-spacing: 1.5px;
            display: flex;
            align-items: center;
            color: var(--text-primary);
            text-shadow: 1px 1px 3px rgba(0,0,0,0.3);
        }

        nav {
            display: flex;
            align-items: center;
        }

        .nav-links {
            list-style: none;
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .nav-links li {
            position: relative;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--text-secondary);
            font-size: 1rem;
            font-weight: 500;
            transition: all 0.3s ease;
            position: relative;
            padding-bottom: 8px;
            letter-spacing: 0.5px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .nav-links a:hover {
            color: var(--accent-color);
            transform: scale(1.05);
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: 0;
            left: 0;
            background-color: var(--accent-color);
            transition: width 0.3s ease;
        }

        .nav-links a:hover::after {
            width: 100%;
        }

        .account-dropdown {
            position: relative;
        }

        .account-toggle {
            display: flex;
            align-items: center;
            cursor: pointer;
            transition: all 0.3s ease;
            font-weight: 600;
            gap: 8px;
        }

        .account-dropdown .dropdown-content {
            display: none;
            position: absolute;
            right: 0;
            top: 100%;
            background-color: var(--text-primary);
            min-width: 250px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            border-radius: 10px;
            overflow: hidden;
            z-index: 1000;
            margin-top: 15px;
        }

        .account-dropdown.active .dropdown-content {
            display: block;
            animation: dropdownSlideIn 0.3s ease;
        }

        .dropdown-content li a {
            color: var(--gradient-middle);
            padding: 12px 15px;
            display: flex;
            align-items: center;
            transition: all 0.3s ease;
            gap: 10px;
        }

        .dropdown-content li a:hover {
            background-color: rgba(46, 204, 113, 0.1);
            color: var(--gradient-start);
        }

        .dropdown-content .logout a {
            color: #e74c3c;
        }

        .dropdown-content .logout a:hover {
            background-color: rgba(231, 76, 60, 0.1);
        }

        @media screen and (max-width: 768px) {
            .nav-links {
                display: none;
                flex-direction: column;
                width: 100%;
                position: absolute;
                top: 60px;
                left: 0;
                background: linear-gradient(135deg, var(--gradient-start), var(--gradient-middle));
                text-align: center;
                padding: 20px 0;
                box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            }

            .nav-links.active {
                display: flex;
            }
        }

        /* Hamburger Menu Styles */
        .hamburger {
            display: none;
            flex-direction: column;
            cursor: pointer;
        }

        .hamburger span {
            height: 3px;
            width: 25px;
            background: var(--text-primary);
            margin: 4px 0;
            transition: 0.4s;
            border-radius: 2px;
        }

        @media screen and (max-width: 768px) {
            .hamburger {
                display: flex;
            }
        }
    </style>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const hamburger = document.querySelector(".hamburger");
            const navLinks = document.querySelector(".nav-links");
            const accountDropdown = document.querySelector(".account-dropdown");

            // Hamburger menu toggle
            hamburger.addEventListener("click", () => {
                navLinks.classList.toggle("active");
                hamburger.classList.toggle("active");
            });

            // Close mobile menu when a link is clicked
            navLinks.addEventListener("click", (e) => {
                if (e.target.tagName === 'A') {
                    navLinks.classList.remove("active");
                    hamburger.classList.remove("active");
                }
            });

            // Account dropdown toggle
            if (accountDropdown) {
                const accountToggle = accountDropdown.querySelector(".account-toggle");
                accountToggle.addEventListener("click", (e) => {
                    e.stopPropagation();
                    accountDropdown.classList.toggle("active");
                });

                // Close dropdown when clicking outside
                document.addEventListener("click", (e) => {
                    if (!accountDropdown.contains(e.target)) {
                        accountDropdown.classList.remove("active");
                    }
                });
            }
        });
    </script>
</header>