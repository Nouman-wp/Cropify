
<head>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            /* Enhanced Teal Color Palette */
            --primary-color: #1abc9c;       /* Soft teal */
            --secondary-color: #16a085;     /* Deep teal */
            --accent-color: #2ecc71;        /* Bright green accent */
            --text-color: #2c3e50;          /* Dark blue-gray */
            --background-color: #f0f4f7;    /* Soft gray-blue */
            --white: #ffffff;
            --transition-speed: 0.3s;
            --hover-color: #2ed573;         /* Bright green hover state */
            --dropdown-bg: #e8f4f2;         /* Very soft teal background */
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', 'Segoe UI', Roboto, sans-serif;
        }

        body {
            background-color: var(--background-color);
            color: var(--text-color);
            line-height: 1.6;
            padding-top: 80px;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: linear-gradient(135deg, var(--secondary-color), var(--primary-color));
            color: var(--white);
            padding: 15px 5%;
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
            box-shadow: 0 6px 20px rgba(22, 160, 133, 0.2);
            transition: all var(--transition-speed) ease;
        }

        .logo {
            font-size: 1.75rem;
            font-weight: 800;
            letter-spacing: 1.5px;
            display: flex;
            align-items: center;
            color: var(--white);
            text-shadow: 1px 1px 3px rgba(0,0,0,0.3);
        }

        nav {
            display: flex;
            align-items: center;
        }

        .nav-links {
            list-style: none;
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .nav-links li {
            position: relative;
        }

        .nav-links a {
            text-decoration: none;
            color: rgba(255,255,255,0.9);
            font-size: 1rem;
            font-weight: 500;
            transition: all var(--transition-speed) ease;
            position: relative;
            padding-bottom: 8px;
            letter-spacing: 0.5px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .nav-links a:hover {
            color: var(--accent-color);
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: 0;
            left: 0;
            background-color: var(--accent-color);
            transition: width var(--transition-speed) ease;
        }

        .nav-links a:hover::after {
            width: 100%;
        }

        .hamburger {
            display: none;
            flex-direction: column;
            cursor: pointer;
        }

        .hamburger span {
            height: 3px;
            width: 25px;
            background: var(--white);
            margin: 4px 0;
            transition: 0.4s;
            border-radius: 2px;
        }

        .account-dropdown {
            position: relative;
        }

        .account-toggle {
            display: flex;
            align-items: center;
            cursor: pointer;
            transition: color var(--transition-speed) ease;
            font-weight: 600;
            gap: 8px;
        }

        .account-toggle:hover {
            color: var(--accent-color);
        }

        .profile-img, .profile-placeholder {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid rgba(46, 204, 113, 0.6);
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
            transition: transform var(--transition-speed) ease;
        }

        .profile-placeholder {
            background-color: var(--white);
            color: var(--secondary-color);
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 1.5rem;
        }

        .profile-img:hover, .profile-placeholder:hover {
            transform: scale(1.1);
        }

        .account-dropdown .dropdown-content {
            display: none;
            position: absolute;
            right: 0;
            top: 100%;
            background-color: var(--dropdown-bg);
            min-width: 250px;
            box-shadow: 0 10px 25px rgba(22, 160, 133, 0.1);
            border-radius: 10px;
            overflow: hidden;
            z-index: 1000;
            margin-top: 15px;
            border: 1px solid rgba(22, 160, 133, 0.1);
        }

        .account-dropdown.active .dropdown-content {
            display: block;
            animation: dropdownSlideIn var(--transition-speed) ease;
        }

        .dropdown-content li {
            margin: 0;
        }

        .dropdown-content li a {
            color: var(--secondary-color);
            padding: 12px 15px;
            display: flex;
            align-items: center;
            transition: all var(--transition-speed) ease;
            gap: 10px;
        }

        .dropdown-content li a:hover {
            background-color: rgba(46, 204, 113, 0.1);
            color: var(--primary-color);
        }

        .dropdown-content .logout a {
            color: #e74c3c;
        }

        .dropdown-content .logout a:hover {
            background-color: rgba(231, 76, 60, 0.1);
        }

        @keyframes dropdownSlideIn {
            from {
                opacity: 0;
                transform: translateY(-15px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @media screen and (max-width: 768px) {
            .nav-links {
                display: none;
                flex-direction: column;
                width: 100%;
                position: absolute;
                top: 60px;
                left: 0;
                background: linear-gradient(135deg, var(--secondary-color), var(--primary-color));
                text-align: center;
                padding: 20px 0;
                box-shadow: 0 10px 20px rgba(0,0,0,0.1);
                border-top: 1px solid rgba(255,255,255,0.1);
            }

            .nav-links.active {
                display: flex;
            }

            .nav-links li {
                margin: 15px 0;
            }

            .hamburger {
                display: flex;
            }
        }

        main {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
    </style>
</head>
<body>
    <header>
        <div class="logo">🌾 Farmer's Marketplace</div>
        <nav>
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/buy">Buy Crops</a></li>
                <li><a href="/sell">Sell Crops</a></li>
                <li><a href="/prices">Market Prices</a></li>

                <!-- Logged Out State -->
                <li class="account-dropdown">
                    <span class="account-toggle">
                        <i class="fa fa-user"></i> Account <i class="fa fa-caret-down"></i>
                    </span>
                    <ul class="dropdown-content">
                        <li><a href="/signup"><i class="fa fa-user-plus"></i> Sign Up</a></li>
                        <li><a href="/login"><i class="fa fa-lock"></i> Login</a></li>
                    </ul>
                </li>

                <!-- Logged In State (uncomment to switch)
                <li class="account-dropdown">
                    <span class="account-toggle">
                        <i class="fa fa-user-circle profile-placeholder"></i>
                        John Farmer <i class="fa fa-caret-down"></i>
                    </span>
                    <ul class="dropdown-content">
                        <li><a href="/dashboard"><i class="fa fa-chart-line"></i> My Dashboard</a></li>
                        <li><a href="/profile"><i class="fa fa-user-edit"></i> Profile</a></li>
                        <li><a href="/orders"><i class="fa fa-shopping-basket"></i> My Orders</a></li>
                        <li class="logout"><a href="/logout"><i class="fa fa-sign-out-alt"></i> Logout</a></li>
                    </ul>
                </li>
                -->
            </ul>

            <div class="hamburger">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </nav>
    </header>

    <main>
        <h1>Welcome to Farmer's Marketplace</h1>
        <p>Connect with local farmers, buy fresh produce, and support your local agricultural community.</p>
    </main>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const hamburger = document.querySelector(".hamburger");
            const navLinks = document.querySelector(".nav-links");
            const accountDropdown = document.querySelector(".account-dropdown");

            // Hamburger menu toggle
            hamburger.addEventListener("click", () => {
                navLinks.classList.toggle("active");
                hamburger.classList.toggle("active");
            });

            // Close mobile menu when a link is clicked
            navLinks.addEventListener("click", (e) => {
                if (e.target.tagName === 'A') {
                    navLinks.classList.remove("active");
                    hamburger.classList.remove("active");
                }
            });

            // Account dropdown toggle
            if (accountDropdown) {
                const accountToggle = accountDropdown.querySelector(".account-toggle");
                accountToggle.addEventListener("click", (e) => {
                    e.stopPropagation();
                    accountDropdown.classList.toggle("active");
                });

                // Close dropdown when clicking outside
                document.addEventListener("click", (e) => {
                    if (!accountDropdown.contains(e.target)) {
                        accountDropdown.classList.remove("active");
                    }
                });
            }
        });
    </script>
</body>
